#!/bin/bash

suffix=$1

mkdir -p failures-$suffix

LAST=$(ls failures-$suffix/ 2>/dev/null | sed 's/failure-//; s/\.log//' | sort -n | tail -1)
if [ -z "$LAST" ]; then
  FAILURE_COUNT=1
else
  FAILURE_COUNT=$((LAST + 1))
fi

while [ 1 ]; do
  printf "."
  grunt karma:static > current-run 2>&1
  if grep -q FAILED current-run; then
    cp current-run "failures-$suffix/failure-$FAILURE_COUNT.log"
    echo "Created failure-$FAILURE_COUNT.log" 
    FAILURE_COUNT=$((FAILURE_COUNT + 1))
  fi
done
